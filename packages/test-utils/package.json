{
  "name": "@ghostframe/test-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "lint": "eslint src --config ../../eslint.config.mjs",
    "typecheck": "tsc --noEmit",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "3 KB"
    }
  ],
  "devDependencies": {
    "typescript": "^6.0.2",
    "tsup": "^8.0.0",
    "@ghostframe/ghostframe": "workspace:*"
  }
}