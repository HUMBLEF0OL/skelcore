{
  "name": "@ghostframe/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "eslint src --config ../../eslint.config.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "7 KB"
    }
  ],
  "devDependencies": {
    "happy-dom": "^20.8.9",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}